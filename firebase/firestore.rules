rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasRole(role) {
      return signedIn()
        && userDoc().exists()
        && userDoc().data.activo == true
        && userDoc().data.rol == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isMesero() {
      return hasRole('mesero');
    }

    function isCocina() {
      return hasRole('cocina');
    }

    function isCaja() {
      return hasRole('caja');
    }

    function isStaff() {
      return isAdmin() || isMesero() || isCocina() || isCaja();
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if isAdmin() || request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    match /business/{docId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /menuCategories/{categoryId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /menuItems/{menuItemId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /tables/{tableId} {
      allow read: if isStaff();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || isMesero() || isCaja();
    }

    match /orders/{orderId} {
      allow read: if isStaff();
      allow create: if isAdmin() || isMesero();
      allow update: if isAdmin() || isMesero() || isCocina() || isCaja();
      allow delete: if isAdmin();
    }

    match /sales/{saleId} {
      allow read: if isAdmin() || isCaja();
      allow create: if isAdmin() || isCaja();
      allow update, delete: if isAdmin();
    }
  }
}
